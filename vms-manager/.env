DATABASE_URL=postgresql://postgres:secret@localhost:5433/postgres
# Server API URL
API_URL=http://172.16.100.11:8000
# Server Agents API URLs, separated by commas
SERVER_AGENTS_API_URLS=http://172.16.200.15:8081
#,http://172.16.200.13:8081,http://172.16.200.14:8081
LIST_BASE_IMAGES_ENDPOINT=/bases
BASE_TEMPLATES_ENDPOINT=/templates
DEFINE_TEMPLATE_ENDPOINT=/templates/define
DELETE_TEMPLATE_ENDPOINT=/templates/delete
BASE_INSTANCES_ENDPOINT=/instances
CREATE_INSTANCE_ENDPOINT=/instances/create
DELETE_INSTANCE_ENDPOINT=/instances/delete
START_INSTANCE_ENDPOINT=/instances/start
STOP_INSTANCE_ENDPOINT=/instances/stop
RESTART_INSTANCE_ENDPOINT=/instances/restart
LIST_INSTANCES_STATUS_ENDPOINT=/instances/status
LIST_SERVERS_STATUS_ENDPOINT=/servers/status
GET_RESOURCE_STATUS_ENDPOINT=/resource-status
SERVER_AGENT_IS_ALIVE_ENDPOINT=/is-alive

# VMs Network parameters
VMS_DNS_1=8.8.8.8
VMS_DNS_2=8.8.4.4

# RouterOS parameters
ROUTEROS_API_URL=172.16.200.2:8728
ROUTEROS_API_USERNAME=admin
ROUTEROS_API_PASSWORD=admin
ROUTEROS_VLAN_BRIDGE=bridge0
# RouterOS tagged bridges, separated by commas
ROUTEROS_TAGGED_BRIDGES=bridge0,ether2
ROUTEROS_EXTERNAL_GATEWAY=10.2.0.1


